# FinAlly environment configuration.
# Copy this file to `.env` and fill in your values:  cp .env.example .env
# The backend reads `.env` from the project root (passed into the container via
# --env-file / docker-compose env_file).

# ── Required ─────────────────────────────────────────────────────────────────
# OpenRouter API key — powers the LLM chat assistant.
# Get one at https://openrouter.ai/keys
# (Not needed if you run entirely with LLM_MOCK=true.)
OPENROUTER_API_KEY=your-openrouter-api-key-here

# ── Optional ─────────────────────────────────────────────────────────────────
# Massive (Polygon.io) API key for real market data.
#   set & non-empty → backend uses the Massive REST API for live prices
#   empty / unset    → backend uses the built-in market simulator (recommended)
# Read once at startup; changing it requires a container restart.
MASSIVE_API_KEY=

# Deterministic mock LLM responses instead of calling OpenRouter.
#   true  → canned, keyword-matched responses (fast, free, used by E2E tests)
#   false → real LLM calls via OpenRouter (default)
LLM_MOCK=false
