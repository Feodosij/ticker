# macOS
.DS_Store

# Secrets — never commit
.env

# ── Frontend (Node) ────────────────────────────────────────────────────────
frontend/node_modules/
frontend/.next/
frontend/out/
frontend/coverage/
frontend/playwright-report/
frontend/test-results/
frontend/*.tsbuildinfo
frontend/next-env.d.ts

# ── Backend (Python / uv) ──────────────────────────────────────────────────
backend/.venv/
backend/**/__pycache__/
backend/**/*.pyc
backend/.coverage
backend/.pytest_cache/

# ── Database ────────────────────────────────────────────────────────────────
db/*.db
db/*.sqlite3

# ── Claude Code ─────────────────────────────────────────────────────────────
.claude/settings.local.json

# ── Editors ──────────────────────────────────────────────────────────────────
.vscode/
.idea/
